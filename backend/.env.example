FITMATCH_ENV=development
FITMATCH_API_PREFIX=/api
FITMATCH_DATABASE_URL=postgresql://fitmatch:fitmatch@localhost:5432/fitmatch
FITMATCH_REDIS_URL=redis://localhost:6379/0
FITMATCH_LOG_LEVEL=INFO
FITMATCH_ERROR_REPORTING_DSN=
FITMATCH_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FITMATCH_AUTH_PROVIDER=supabase
FITMATCH_RESUME_STORAGE_BUCKET=resumes
FITMATCH_LLM_PROVIDER=openai
FITMATCH_EMBEDDING_MODEL=text-embedding-3-small
FITMATCH_EMBEDDING_DIMENSIONS=1536
FITMATCH_SCRAPE_RETRY_ATTEMPTS=3
FITMATCH_SCRAPE_TIER1_INTERVAL_MINUTES=360
FITMATCH_SCRAPE_TIER2_INTERVAL_MINUTES=1440
FITMATCH_STRIPE_SECRET_KEY=
FITMATCH_STRIPE_WEBHOOK_SECRET=
FITMATCH_STRIPE_PRO_PRICE_ID=price_pro_monthly
FITMATCH_STRIPE_LIFETIME_PRICE_ID=price_lifetime_one_time
FITMATCH_APP_URL=http://localhost:3000
